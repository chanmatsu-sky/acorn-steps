{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local", ".env"],
  "globalEnv": ["NODE_ENV", "DATABASE_URL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "^generate"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^generate"]
    },
    "lint": {
      "dependsOn": ["^generate"]
    },
    "typecheck": {
      "dependsOn": ["^build", "^generate"]
    },
    "test": {
      "dependsOn": ["^build", "^generate"]
    },
    "generate": {
      "cache": false
    },
    "migrate": {
      "cache": false,
      "persistent": false
    },
    "studio": {
      "cache": false,
      "persistent": true
    }
  }
}
