# Copy to .env.local for local development.
# packages/db reads DATABASE_URL via prisma.

# Database (matches docker-compose.yml)
DATABASE_URL="postgresql://acorn:acorn@localhost:5433/acornsteps?schema=public"

# Auth (generated via: openssl rand -base64 32)
AUTH_SECRET=""

# Web app
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# Web Push (VAPID) — generate via: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"
