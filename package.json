{
  "name": "acorn-steps",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source baby tracking PWA — feeding, diaper, sleep with real-time parent sharing. JP/EN/VI.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:chanmatsu-sky/acorn-steps.git"
  },
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @acorn-steps/db generate",
    "db:migrate": "pnpm --filter @acorn-steps/db migrate",
    "db:studio": "pnpm --filter @acorn-steps/db studio",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.60.1"
  }
}
