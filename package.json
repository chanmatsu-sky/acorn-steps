{
  "name": "acorn-steps",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source baby tracking PWA — feeding, diaper, sleep with real-time parent sharing. JP/EN/VI.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:chanmatsu-sky/acorn-steps.git"
  },
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @acorn-steps/db generate",
    "db:migrate": "pnpm --filter @acorn-steps/db migrate",
    "db:studio": "pnpm --filter @acorn-steps/db studio",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
